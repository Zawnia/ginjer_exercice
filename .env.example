# GCP
GOOGLE_APPLICATION_CREDENTIALS=./.secret/gcp-sa.json
GCP_PROJECT_ID=ginjer-440122

# LLM
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
GEMINI_API_KEY=
OPENAI_API_KEY=

# Langfuse
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=http://localhost:3000
LANGFUSE_ENABLED=true

# Pipeline
FALLBACK_CONFIDENCE_THRESHOLD=0.7
WEB_VERIFY_THRESHOLD=0.85
PROMPT_CACHE_TTL_SECONDS=300

# BigQuery
BIGQUERY_TABLE=ginjer-440122.ia_eng_interview.ads

# Results persistence
SQLITE_DB_PATH=data/results/pipeline_results.db

# Media fetcher
MEDIA_MAX_SIZE_BYTES=52428800
MEDIA_IMAGE_TIMEOUT=30.0
MEDIA_VIDEO_TIMEOUT=120.0
MEDIA_MAX_RETRIES=3
